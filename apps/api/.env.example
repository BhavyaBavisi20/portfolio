PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/portfolio
CORS_ORIGIN=http://localhost:5173

# Hugging Face configuration for the RAG assistant
HUGGINGFACE_API_KEY=hf_your_token_here
HUGGINGFACE_PROVIDER=hf-inference
HUGGINGFACE_CHAT_MODEL=katanemo/Arch-Router-1.5B
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional contact email settings
DISABLE_EMAIL_NOTIFICATIONS=false

# Resend (required for contact email notifications)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=Portfolio <noreply@your-verified-domain.com>
RESEND_TO=you@example.com
